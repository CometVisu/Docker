#!/bin/sh
set -e

NO_ENTRYPOINT_APACHE=${NO_ENTRYPOINT_APACHE:-false}
NO_ENTRYPOINT_KNXD=${NO_ENTRYPOINT_KNXD:-false}

CGI_URL_PATH=${CGI_URL_PATH:-/cgi-bin/}

if [ x"${BACKEND_NAME}" = x"default" ] || [ x"${BACKEND_NAME}" = x"" ]; then
    BACKEND_NAME="knxd"
fi

BACKEND_KNXD=${BACKEND_KNXD:-${CGI_URL_PATH}l}
BACKEND_OPENHAB=${BACKEND_OPENHAB:-$CGI_URL_PATH}
export BASE_URL=${BACKEND_KNXD%?}

echo "Server side configuration parameters:"
echo "BACKEND_NAME: '${BACKEND_NAME}'"
echo "BACKEND_KNXD: '${BACKEND_KNXD}'"
echo "BACKEND_MQTT: '${BACKEND_MQTT}'"
echo "BACKEND_OPENHAB: '${BACKEND_OPENHAB}'"
echo "CGI_URL_PATH: '${CGI_URL_PATH}' (deprecated)"
echo "knxd baseURL: '${BASE_URL}'"

echo "#!/bin/sh" >  /usr/local/bin/healthcheck
chmod a+x /usr/local/bin/healthcheck

if [ x"${STOP_ON_BAD_HEALTH}" = x"true" ]
    then echo "badhealth='apachectl stop'" >> /usr/local/bin/healthcheck
    else echo "badhealth='true'" >> /usr/local/bin/healthcheck
fi

# Helper function for healthcheck failures - logs error to container stdout (docker logs)
echo 'healthcheck_fail() {' >> /usr/local/bin/healthcheck
echo '    echo "$1" | tee /proc/1/fd/1' >> /usr/local/bin/healthcheck
echo '    $badhealth > /dev/null 2>&1' >> /usr/local/bin/healthcheck
echo '    exit 1' >> /usr/local/bin/healthcheck
echo '}' >> /usr/local/bin/healthcheck

if [ x"${ADDITIONAL_HEALTHCHECK}" != x"" ]; then
    echo "${ADDITIONAL_HEALTHCHECK}" >> /usr/local/bin/healthcheck
fi

if [ "${KNXD_PARAMETERS}" != "" ] || [ "${KNX_INTERFACE}" != "" ]; then
    if [ "${KNXD_PARAMETERS}" != "" ]; then
        echo "creating knxd config file completely based on values from KNXD_PARAMETERS (${KNXD_PARAMETERS})"
        echo ""
        echo "NOTE: we can't check whether your KNXD_PARAMETERS is valid. When the" 
        echo "knxd doesn't start up a bad KNXD_PARAMETERS is most likely the case."
        echo "Consider to remove it and use the individual options instead!"
    else
        BAD_KNXD_CONFIG="false"
        if [ x"${KNX_PA}" = x"" ]; then
            echo 'ERROR: you MUST specify "KNX_PA" when using the knxd backend!'
            BAD_KNXD_CONFIG="true"
        fi
        if [ x"${KNX_CLIENT_PAS}" = x"" ]; then
            echo 'ERROR: you MUST specify "KNX_CLIENT_PAS" when using the knxd backend!'
            BAD_KNXD_CONFIG="true"
        fi
        if [ x"${KNX_INTERFACE}" = x"" ]; then
            echo 'ERROR: you MUST specify "KNX_INTERFACE" when using the knxd backend!'
            BAD_KNXD_CONFIG="true"
        fi
        if [ x"${BAD_KNXD_CONFIG}" = x"true" ]; then
            echo 'FATAL ERROR: stopping, as no valid knxd config given.'
            exit 1
        fi

        KNX_DAEMON_OPTIONS=""
        if [ x"${NO_ENTRYPOINT_KNXD}" = x"false" ]; then
            KNX_DAEMON_OPTIONS=" -d/var/log/knxd.log"
        fi
        KNXD_PARAMETERS="-e ${KNX_PA} -E ${KNX_CLIENT_PAS} -u${KNX_DAEMON_OPTIONS} -c ${KNX_INTERFACE_OPTIONS} -b ${KNX_INTERFACE}"
        echo "creating knxd config file from single parameters (${KNXD_PARAMETERS})"
    fi
    /usr/lib/knxd_args ${KNXD_PARAMETERS} > /etc/knxd.ini
    # modify knxd.conf to use knxd.ini
    sed -i 's/^KNXD_OPTS=.*/KNXD_OPTS=\/etc\/knxd.ini/' /etc/knxd.conf

    if [ x"${NO_ENTRYPOINT_KNXD}" = x"false" ]; then
        KNXD_BINARY=/usr/bin/knxd
        KNXD_VERSION=$(${KNXD_BINARY} --version 2>&1 | sed 's/^[^ ]* //')
        echo -n "starting knxd - version: " && echo "${KNXD_VERSION}"

        export LOGIN_EXTRA_CONFIG='"knxdRuntimeVersion":"'${KNXD_VERSION}'"'
        echo "LOGIN_EXTRA_CONFIG: '${LOGIN_EXTRA_CONFIG}'"

        ${KNXD_BINARY} /etc/knxd.ini
        sleep 5
        if [ ! -S "/run/knx" ]; then 
            echo 'Error: knxd socket does not exist'
            echo 'Running processes:'
            ps aux | grep knxd
            echo 'Directory listing of /run:'
            ls -la /run;
            echo '/var/log/knxd.log:'
            cat /var/log/knxd.log || true
            exit 1; 
        fi
        chmod a+rwx /run/knx || true

        echo "if ! pgrep -f knxd >/dev/null; then healthcheck_fail 'Error: knxd not running'; fi" >> /usr/local/bin/healthcheck
        echo "if [ ! -S /run/knx ]; then healthcheck_fail 'Error: knxd socket does not exist'; fi" >> /usr/local/bin/healthcheck

        # Start cometvisu-knxd-fcgi in standalone socket mode (the binary's intended usage).
        export FCGI_SOCKET=/run/cometvisu-fcgi.sock
        export LONGPOLL_TIMEOUT_SEC=${LONGPOLL_TIMEOUT_SEC:-300}
        export DEBUG_BACKEND=${DEBUG_BACKEND:-}
        # Extract knxd client count from KNX_CLIENT_PAS (format: <addr>:<count>)
        KNXD_CLIENT_COUNT="${KNX_CLIENT_PAS##*:}"
        export FCGI_WORKERS=${FCGI_WORKERS:-20}
        if [ "${FCGI_WORKERS}" -gt "${KNXD_CLIENT_COUNT}" ]; then
            echo "WARNING: FCGI_WORKERS (${FCGI_WORKERS}) exceeds knxd client count (${KNXD_CLIENT_COUNT}), reducing to ${KNXD_CLIENT_COUNT}"
            export FCGI_WORKERS="${KNXD_CLIENT_COUNT}"
        fi
        echo "LONGPOLL_TIMEOUT_SEC: '${LONGPOLL_TIMEOUT_SEC}'"
        echo "FCGI_WORKERS: '${FCGI_WORKERS}'"
        if [ x"${DEBUG_BACKEND}" = x"1" ]; then
            echo "DEBUG_BACKEND: enabled"
        fi
        echo -n "starting cometvisu-knxd-fcgi - version: " && cometvisu-knxd-fcgi --version
        cometvisu-knxd-fcgi &
        sleep 2
        if [ ! -S "${FCGI_SOCKET}" ]; then
            echo "Error: cometvisu-knxd-fcgi socket does not exist at ${FCGI_SOCKET}";
            exit 1;
        fi
        chmod a+rwx "${FCGI_SOCKET}"
        echo "if ! pgrep -f cometvisu-knxd-fcgi >/dev/null; then healthcheck_fail 'Error: cometvisu-knxd-fcgi not running'; fi" >> /usr/local/bin/healthcheck
        echo "if [ ! -S \"\${FCGI_SOCKET}\" ]; then healthcheck_fail 'Error: cometvisu-knxd-fcgi socket does not exist'; fi" >> /usr/local/bin/healthcheck
    fi
fi

# Tell the CometVisu to path to the login
echo ''                                                             >> $APACHE_CONFDIR/conf-available/cv-docker-php.conf
echo '<FilesMatch "visu_config.*xml$">'                             >> $APACHE_CONFDIR/conf-available/cv-docker-php.conf
if [ x"${BACKEND_NAME}" != x"" ]; then
    echo "    Header set X-CometVisu-Backend-Name ${BACKEND_NAME}"            >> $APACHE_CONFDIR/conf-available/cv-docker-php.conf
fi
if [ x"${BACKEND_KNXD}" != x"" ]; then
    echo "    Header set X-CometVisu-Backend-KNXD-Url ${BACKEND_KNXD}"        >> $APACHE_CONFDIR/conf-available/cv-docker-php.conf
fi
if [ x"${BACKEND_MQTT}" != x"" ]; then
    echo "    Header set X-CometVisu-Backend-MQTT-Url ${BACKEND_MQTT}"        >> $APACHE_CONFDIR/conf-available/cv-docker-php.conf
fi
if [ x"${BACKEND_OPENHAB}" != x"" ]; then
    echo "    Header set X-CometVisu-Backend-OpenHAB-Url ${BACKEND_OPENHAB}"  >> $APACHE_CONFDIR/conf-available/cv-docker-php.conf
fi
echo '</FilesMatch>'                                                >> $APACHE_CONFDIR/conf-available/cv-docker-php.conf

if [ x"${BACKEND_PROXY_SOURCE}" != x"" ] && [ x"${BACKEND_PROXY_TARGET}" != x"" ]; then
    echo "proxying ${BACKEND_PROXY_SOURCE} -> ${BACKEND_PROXY_TARGET}"
    # exclude manager backend from proxying
    echo "ProxyPass" /rest/manager !                                        >  $APACHE_CONFDIR/conf-available/cv-proxy.conf
    echo "ProxyPass ${BACKEND_PROXY_SOURCE} ${BACKEND_PROXY_TARGET}"        >> $APACHE_CONFDIR/conf-available/cv-proxy.conf
    echo "ProxyPassReverse ${BACKEND_PROXY_TARGET} ${BACKEND_PROXY_SOURCE}" >> $APACHE_CONFDIR/conf-available/cv-proxy.conf

    a2enmod proxy_http > /dev/null
    a2enconf cv-proxy.conf > /dev/null
fi

if [ x"${NO_ENTRYPOINT_APACHE}" = x"false" ]; then

    if [ -e "/var/log/apache2/access.log" ]; then
        rm -f /var/log/apache2/access.log
    fi

    if [ x"${ACCESS_LOG}" = x"true" ]
        then ln -f -s /dev/stdout /var/log/apache2/access.log
        else ln -f -s /dev/null /var/log/apache2/access.log
    fi

    echo "if ! curl -f -s http://localhost/ >/dev/null; then healthcheck_fail 'Error: apache not responding'; fi" >> /usr/local/bin/healthcheck

    # first arg is `-f` or `--some-option`
    if [ x"${1#-}" != x"$1" ]; then
        set -- apache2-foreground "$@"
    fi
fi
  
echo "running '$@'..."
exec "$@"
